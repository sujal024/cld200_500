{
  "name": "employee-crud-app",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2.7.0",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/cds": "^9",
    "@sap/xssec": "^4.13.0"
  },

  
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-employees-crud-ui": "cds watch --open com.employee.employeescrudui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employee-crud-ui": "cds watch --open com.employees.employeecrudui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-customer-crud-ui": "cds watch --open com.employee.customercrudui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy employee-crud-app --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/employees-crud-ui",
    "app/employee-crud-ui",
    "app/customer-crud-ui",
    "app/customer-crud-ui"
  ],
  "cds": {
    "requires": {
      "[hybrid]": {
        "auth": "xsuaa"
      },
      "northwind": {
        "kind": "odata",
        "model": "srv/external/northwind",
        "credentials": {
          "url": "https://services.odata.org/v4/northwind/northwind.svc/"
        }
      }
    }
  }
}
